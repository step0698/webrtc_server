generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Keep this in sync with POSTGRES_SCHEMA.
  schemas  = ["my_schema"]
}

model Room {
  id        String   @id @default(uuid()) @db.Uuid
  roomCode  String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("my_schema")
}
