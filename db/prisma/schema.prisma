generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Keep this in sync with POSTGRES_SCHEMA.
  schemas  = ["sstest"]
}

model Room {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("sstest")
}
