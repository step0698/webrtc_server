{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "types": ["node"],

    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}